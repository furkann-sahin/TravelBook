			"item": [
				{
					"name": "1 - Tur Firması Kayıt Olma",
					"event": [
						{
							"listen": "test",
							"script": {
								"exec": [
									"pm.test('Status code 201 döner', function () {",
									"    pm.response.to.have.status(201);",
									"});",
									"",
									"pm.test('Response JSON formatında', function () {",
									"    pm.response.to.be.json;",
									"});",
									"",
									"pm.test('status alanı success olmalı', function () {",
									"    var jsonData = pm.response.json();",
									"    pm.expect(jsonData.status).to.eql('success');",
									"});",
									"",
									"pm.test('message alanı mevcut', function () {",
									"    var jsonData = pm.response.json();",
									"    pm.expect(jsonData.message).to.be.a('string');",
									"    pm.expect(jsonData.message).to.include('başarıyla kayıt oldu');",
									"});",
									"",
									"pm.test('token alanı mevcut ve string', function () {",
									"    var jsonData = pm.response.json();",
									"    pm.expect(jsonData.token).to.be.a('string');",
									"    pm.expect(jsonData.token.length).to.be.greaterThan(10);",
									"});",
									"",
									"// Token ve companyId kaydet",
									"if (pm.response.code === 201) {",
									"    var jsonData = pm.response.json();",
									"    pm.collectionVariables.set('companyToken', jsonData.token);",
									"    // JWT decode ile companyId çıkar",
									"    try {",
									"        var payload = JSON.parse(atob(jsonData.token.split('.')[1]));",
									"        if (payload.id) {",
									"            pm.collectionVariables.set('companyId', payload.id);",
									"        }",
									"    } catch(e) {",
									"        console.log('Token decode edilemedi, companyId manuel girilmeli');",
									"    }",
									"}"
								],
								"type": "text/javascript"
							}
						}
					],
					"request": {
						"method": "POST",
						"header": [
							{
								"key": "Content-Type",
								"value": "application/json"
							}
						],
						"body": {
							"mode": "raw",
							"raw": "{\n    \"name\": \"Gezgin Turizm\",\n    \"email\": \"info@gezgin.com\",\n    \"password\": \"Sifre123!\",\n    \"phone\": \"02121234567\",\n    \"address\": \"İstanbul, Kadıköy\",\n    \"description\": \"Türkiye'nin en köklü tur firması\"\n}"
						},
						"url": {
							"raw": "{{baseUrl}}/companies/auth/register",
							"host": ["{{baseUrl}}"],
							"path": ["companies", "auth", "register"]
						},
						"description": "Yeni tur firması kaydı oluşturur. Başarılı olursa JWT token ve firma bilgileri döner."
					},
					"response": []
				},
				{
					"name": "2 - Tur Firması Giriş Yapma",
					"event": [
						{
							"listen": "test",
							"script": {
								"exec": [
									"pm.test('Status code 200 döner', function () {",
									"    pm.response.to.have.status(200);",
									"});",
									"",
									"pm.test('Response JSON formatında', function () {",
									"    pm.response.to.be.json;",
									"});",
									"",
									"pm.test('status alanı success olmalı', function () {",
									"    var jsonData = pm.response.json();",
									"    pm.expect(jsonData.status).to.eql('success');",
									"});",
									"",
									"pm.test('message Giriş başarılı olmalı', function () {",
									"    var jsonData = pm.response.json();",
									"    pm.expect(jsonData.message).to.include('Giriş başarılı');",
									"});",
									"",
									"pm.test('token alanı mevcut ve string', function () {",
									"    var jsonData = pm.response.json();",
									"    pm.expect(jsonData.token).to.be.a('string');",
									"    pm.expect(jsonData.token.length).to.be.greaterThan(10);",
									"});",
									"",
									"// Token güncelle",
									"if (pm.response.code === 200) {",
									"    var jsonData = pm.response.json();",
									"    pm.collectionVariables.set('companyToken', jsonData.token);",
									"    try {",
									"        var payload = JSON.parse(atob(jsonData.token.split('.')[1]));",
									"        if (payload.id) {",
									"            pm.collectionVariables.set('companyId', payload.id);",
									"        }",
									"    } catch(e) {",
									"        console.log('Token decode edilemedi');",
									"    }",
									"}"
